# ─────────────────────────────────────────────────────────────
# askbrows — пример переменных окружения.
# Скопируй в .env и заполни. .env в репозиторий НЕ коммитить.
# ─────────────────────────────────────────────────────────────

# --- Общее ---
ENV=development                       # development | production
TZ=Europe/Moscow

# --- Домены ---
# Прод-домен askbrows.ru ещё не куплен, временно:
PUBLIC_SITE_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8000
# На проде: https://askbrows.awwwdde.art

# --- PostgreSQL ---
POSTGRES_USER=askbrows
POSTGRES_PASSWORD=change-me
POSTGRES_DB=askbrows
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async DSN, собирается из переменных выше (asyncpg):
DATABASE_URL=postgresql+asyncpg://askbrows:change-me@postgres:5432/askbrows

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_TTL_MIN=43200                     # 30 дней

# --- Telegram (токен/username пришлём на фазе 2–3) ---
BOT_TOKEN=                            # плейсхолдер, заполнить позже
BOT_USERNAME=                         # без @
TELEGRAM_WEBHOOK_URL=                 # https://<домен>/api/bot/webhook (прод)
TELEGRAM_WEBHOOK_SECRET=change-me

# --- Бизнес-правила ---
CANCELLATION_HOURS=6                  # отмена/перенос не позднее N часов до визита

# --- S3-совместимое хранилище (Selectel / Yandex Object Storage) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-1

# --- CORS ---
CORS_ORIGINS=http://localhost:5173
